# top-level dataset dir only (NOT cardioseg/data/ source)
/data/
# machine-specific absolute paths (copy from paths.example.yaml)
paths.yaml
# vendored external generation tools (quarantined, MIT; fetched on demand, never a core dep)
external/
# mri-sim (TypeScript app) build artifacts
mri-sim/node_modules/
mri-sim/dist/
mri-sim/debug-shot.png
scripts/_eda_out/
__pycache__/
*.pyc
.pytest_cache/
*.stl
*.pth
.ruff_cache/
.import_linter_cache/
.grimp_cache/

# archmap: graph.json IS committed (the diffable architecture artifact); the interactive viewer shell is
# regenerated (template-identical, ~700KB of vendored libs) locally / in the Pages workflow — not committed.
docs/architecture/index.html

# Virtualenv
.venv/
runs/
# stray logs (training runs, debug dumps) — never in the repo
*.log
logs/
# Claude Code transient session lock (scheduled-wakeup state, not repo content)
.claude/scheduled_tasks.lock

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# cardioview generated assets (regenerable)
cardioview/out/*.html
cardioview/out/*.glb
cardioview/web/public/data/
cardioview/web/node_modules/
cardioview/web/dist/
cardioview/web/debug-shot.png
cardioview/web/public/models/
cardioview/web/debug-import.png

# bd issue tracker: sync via issues.jsonl in git (over https), like mindscape. The nested
# .beads/.gitignore keeps the Dolt engine (embeddeddolt/, backup/, locks) out; issues.jsonl +
# config.yaml + metadata.json + hooks are tracked so the tracker rides with the code repo.
.beads-credential-key
cardioview/web/debug-*.png

# private job-application material — never public
applications/
# elevator pitch (private note, not public)
elevator.txt

# Private/local-only docs (generic pattern — reveals no intent in the ignore list itself)
*.local.md
.local/

# MLflow local tracking store (Phase 1; runs/ + RESULTS.json stay canonical)
mlruns/
mlflow.db
mlartifacts/
.mlflow_cache/
.staging/
*.egg-info/

# Belt-and-suspenders for the Windows-path-on-POSIX leak (real fix = core.paths.resolve_data_root,
# which raises before any such dir is created). These catch the ASCII-':' form; the NTFS-reserved
# form uses U+F03A so it won't match here — the resolver is what actually prevents it.
D:/
data/volumetric/

# coverage.py artifacts
.coverage*
coverage.xml
htmlcov/
